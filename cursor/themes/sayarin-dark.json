  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#6b8fa3ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.block.documentation",
        "comment.block.doc"
      ],
      "settings": {
        "foreground": "#5a7a90ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#00ff88ff"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00ffccff"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.quoted.regexp"
      ],
      "settings": {
        "foreground": "#ff00aaff"
      }
    },
    {
